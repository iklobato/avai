# avai — environment variables
#
# Copy to `.env`, fill in the keys you want active, and either source it
# (`set -a; source .env; set +a`) or pass `--env-file .env` to docker.
# Everything is optional; missing keys silently disable their enricher.

# ----- LLM judge (one of these is required for the judge to run) -----

# Claude Code OAuth (preferred when present). Bypasses litellm and uses
# the Claude Code identity flow.
# CLAUDE_CODE_OAUTH_TOKEN=

# Standard Anthropic API key (used via litellm).
# ANTHROPIC_API_KEY=

# Any other litellm-supported provider (OpenAI, Gemini, Bedrock, …)
# follows the same pattern — set the conventional env var.
# OPENAI_API_KEY=


# ===== Threat-intel enrichment =====
# Each enricher's env var is the gate. If the var is unset, the enricher
# is skipped at startup (you'll see a one-line note in the monitor log).
# Keyless sources always run.

# abuse.ch — unified key for MalwareBazaar, URLhaus, ThreatFox. Free.
# Their 2024 policy added free Auth-Key throttling to all three APIs.
# Sign up (once): https://auth.abuse.ch/
# ABUSE_CH_AUTH_KEY=

# VirusTotal v3 — files, URLs, domains, IPs. Free: 4 rpm / 500 rpd.
# Sign up: https://www.virustotal.com/gui/my-apikey
# VT_API_KEY=

# AbuseIPDB — IP abuse-confidence score. Free: 1000 rpd.
# Sign up: https://www.abuseipdb.com/account/api
# ABUSEIPDB_API_KEY=

# GreyNoise Community — "is this IP background noise?" Free.
# Sign up: https://viz.greynoise.io/account/api-key
# GREYNOISE_API_KEY=

# Google Safe Browsing v4 — phishing / malware URLs. Free: 10k rpd.
# Sign up: https://console.cloud.google.com → enable "Safe Browsing API"
# GOOGLE_SAFE_BROWSING_API_KEY=

# PhishTank — community phishing DB. Free.
# Sign up: https://phishtank.org/api_register.php
# PHISHTANK_API_KEY=

# GitHub Advisory Database — curated CVEs. Free (any PAT with public_repo).
# Generate: https://github.com/settings/tokens
# GITHUB_TOKEN=

# NVD — optional key bumps rate limit from 5 to 50 req / 30 s.
# Sign up: https://nvd.nist.gov/developers/request-an-api-key
# NVD_API_KEY=


# ===== Linux monitor (compose / docker run) =====

# Set to /host when running the monitor in a container with host paths
# bind-mounted under /host. Native installs leave this unset.
# HOST_PREFIX=/host

# Required for systemctl to talk to the host's systemd in a container.
# DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket
